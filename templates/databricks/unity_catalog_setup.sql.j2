{#---
name: Unity Catalog Setup
description: Generate SQL statements to set up a Unity Catalog namespace with catalog, schemas, and permissions for a medallion architecture.
category: databricks
variables: catalog, schemas, owner, groups
---#}

-- =============================================================================
-- Unity Catalog Setup: {{ catalog }}
-- Generated by ClawData
-- =============================================================================

-- ── Create Catalog ──────────────────────────────────────────────────

CREATE CATALOG IF NOT EXISTS {{ catalog }}
COMMENT 'Data catalog managed by ClawData';

ALTER CATALOG {{ catalog }} OWNER TO `{{ owner | default('data-engineering') }}`;

-- ── Create Schemas (Medallion Architecture) ─────────────────────────

{%- for schema in schemas | default(['bronze', 'silver', 'gold', 'staging']) %}

CREATE SCHEMA IF NOT EXISTS {{ catalog }}.{{ schema }}
COMMENT '{{ schema | capitalize }} layer of the medallion architecture';

{%- endfor %}

-- ── Volumes for File Storage ────────────────────────────────────────

CREATE VOLUME IF NOT EXISTS {{ catalog }}.{{ (schemas | default(['bronze']))[0] }}.raw_files
COMMENT 'Landing zone for raw ingested files';

CREATE VOLUME IF NOT EXISTS {{ catalog }}.{{ (schemas | default(['bronze']))[0] }}.checkpoints
COMMENT 'Streaming checkpoint storage';

-- ── Grants ──────────────────────────────────────────────────────────

{%- if groups %}
{%- for group in groups %}

-- Grants for {{ group.name }}
{%- if group.role | default('reader') == 'reader' %}
GRANT USE CATALOG ON CATALOG {{ catalog }} TO `{{ group.name }}`;
{%- for schema in schemas | default(['bronze', 'silver', 'gold', 'staging']) %}
GRANT USE SCHEMA ON SCHEMA {{ catalog }}.{{ schema }} TO `{{ group.name }}`;
GRANT SELECT ON SCHEMA {{ catalog }}.{{ schema }} TO `{{ group.name }}`;
{%- endfor %}
{%- elif group.role == 'writer' %}
GRANT USE CATALOG ON CATALOG {{ catalog }} TO `{{ group.name }}`;
{%- for schema in schemas | default(['bronze', 'silver', 'gold', 'staging']) %}
GRANT USE SCHEMA ON SCHEMA {{ catalog }}.{{ schema }} TO `{{ group.name }}`;
GRANT SELECT, MODIFY ON SCHEMA {{ catalog }}.{{ schema }} TO `{{ group.name }}`;
{%- endfor %}
{%- elif group.role == 'admin' %}
GRANT ALL PRIVILEGES ON CATALOG {{ catalog }} TO `{{ group.name }}`;
{%- endif %}
{%- endfor %}
{%- else %}

-- Example grants (uncomment and adjust):
-- GRANT USE CATALOG ON CATALOG {{ catalog }} TO `analysts`;
-- GRANT USE SCHEMA ON SCHEMA {{ catalog }}.gold TO `analysts`;
-- GRANT SELECT ON SCHEMA {{ catalog }}.gold TO `analysts`;
-- GRANT ALL PRIVILEGES ON CATALOG {{ catalog }} TO `data-engineering`;
{%- endif %}
