# ClawData Configuration
CLAWDATA_ENV=development
CLAWDATA_SECRET_KEY=change-me-generate-with-python-c-from-cryptography.fernet-import-Fernet-print-Fernet.generate_key().decode()
CLAWDATA_DATABASE_URL=sqlite+aiosqlite:///./clawdata.db

# OpenClaw Gateway (external — user manages separately)
CLAWDATA_OPENCLAW_GATEWAY_HOST=127.0.0.1
CLAWDATA_OPENCLAW_GATEWAY_PORT=18789
CLAWDATA_OPENCLAW_GATEWAY_TOKEN=

# Path overrides (optional)
# CLAWDATA_TEMPLATES_DIR=./templates
# CLAWDATA_SKILLS_DIR=./skills
